+// Gênero: M → '1', F → '2', qualquer outro (vazio, I etc.) → '0' (não informado).
+function generoParaCodigo(g) {
+  var s = String(g || '').trim().toUpperCase();
+  if (s === 'M') return '1';
+  if (s === 'F') return '2';
+  return '0';
+}
+
+// Tipo de telefone: 1 fixo, 2 celular, 3 comercial. Default celular (2).
+function tipoTelefoneParaCodigo(t) {
+  var s = String(t || '').trim();
+  if (s === '1') return '1';
+  if (s === '3') return '3';
+  return '2';
+}
+
+// Recebe cobrança: "Sim" → '2', "Não"/"Nao" → '1', ambíguo → '' (campo omitido).
+function recebeCobrancaParaCodigo(s) {
+  var v = String(s || '').trim().toLowerCase();
+  if (v === 'sim' || v === 's') return '2';
+  if (v === 'não' || v === 'nao' || v === 'n') return '1';
