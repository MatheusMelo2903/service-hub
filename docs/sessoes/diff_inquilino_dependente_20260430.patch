+// Converte data no formato dd/mm/aaaa para mm/dd/yyyy.
+// A API do Superlógica exige formato americano m/d/Y, portanto mês vem antes do dia.
+// m[1]=dia, m[2]=mes, m[3]=ano. A inversão abaixo coloca mes/dia/ano.
+function dataBRtoUS(str) {
+  if (!str) return '';
+  var s = String(str).trim();
+  var m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
+  if (!m) return '';
+  return m[2].padStart(2, '0') + '/' + m[1].padStart(2, '0') + '/' + m[3];
+}
+
+// Igual a dataBRtoUS mas com sufixo " 00:00:00", exigido pelo campo DT_ENTRADA_RES.
+function dataBRtoUSComHora(str) {
+  var d = dataBRtoUS(str);
+  return d ? d + ' 00:00:00' : '';
+}
