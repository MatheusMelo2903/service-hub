+// Detecta se a planilha está no formato unificado (26 colunas A-Z) ou no
+// formato antigo do Superlógica (30+ colunas por posição fixa).
+// Heurística: presença de "Tipo" na col A + "Nome" na col F + "Data Nascimento"
+// em qualquer cabeçalho já é suficiente para distinguir os dois formatos.
+function detectarFormatoPlanilhaUnificada(headers) {
+  if (!headers || headers.length < 6) return 'antigo';
+  var h = headers.map(function(s) { return String(s || '').trim().toLowerCase(); });
+  var temTipo = h[0] === 'tipo';
+  var temNome = h[5] === 'nome';
+  var temDataNasc = h.some(function(s) { return s.indexOf('nascimento') !== -1; });
