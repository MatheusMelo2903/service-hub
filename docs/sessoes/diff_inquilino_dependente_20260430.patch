+var UF_CODIGOS = {
+  'AC':'1','AL':'2','AP':'4','AM':'3','BA':'5','CE':'6','DF':'7',
+  'ES':'8','GO':'9','MA':'10','MT':'13','MS':'12','MG':'11','PA':'14',
+  'PB':'15','PR':'16','PE':'17','PI':'18','RJ':'19','RN':'20',
+  'RS':'23','RO':'21','RR':'22','SC':'24','SP':'25','SE':'26','TO':'27'
+};
+
+// Converte sigla de UF para código numérico do Superlógica.
+// Chama logFn com aviso se a sigla não for reconhecida.
+function ufParaCodigo(sigla, logFn) {
+  if (!sigla) return '';
+  var uf = String(sigla).trim().toUpperCase();
+  var cod = UF_CODIGOS[uf];
+  if (!cod && typeof logFn === 'function') {
+    logFn('UF nao reconhecida: "' + uf + '". Verifique a planilha e ajuste o mapeamento se necessario.');
